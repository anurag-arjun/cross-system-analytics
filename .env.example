# Nexus Analytics — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is gitignored by default.

# HyperSync API token (required for EVM ingestion)
# Get one free at https://app.envio.dev/api-tokens
HYPERSYNC_TOKEN=your_token_here

# Optional: override default JSON-RPC endpoints
# BASE_RPC_URL=https://mainnet.base.org
# ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
